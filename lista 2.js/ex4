//4. Fazer um algoritmo que converta uma determinada quantia em Reais
//para uma das seguintes moedas de acordo com a opção do usuário:
//Moeda Preço por Litro
//1 – Euro R$ 5,418
//2 – Libra Esterlina R$ 6,336
//3 – Dólar R$ 5,189

let prompt = require('prompt-sync')();
function converterReais() {
    let valorReais = parseFloat(prompt('Digite a quantia em Reais: '));
    let opcao = parseInt(prompt('Escolha a moeda para conversão (1 - Euro, 2 - Libra Esterlina, 3 - Dólar): '));
    let valorConvertido;
    switch (opcao) {
        case 1:
            valorConvertido = valorReais / 5.418;
            console.log(`O valor convertido para Euro é: € ${valorConvertido.toFixed(2)}`);
            break;
        case 2:
            valorConvertido = valorReais / 6.336;
            console.log(`O valor convertido para Libra Esterlina é: £ ${valorConvertido.toFixed(2)}`);
            break;
        case 3:
            valorConvertido = valorReais / 5.189;
            console.log(`O valor convertido para Dólar é: $ ${valorConvertido.toFixed(2)}`);
            break;
        default:
            console.log('Opção de moeda inválida.');
    }
}
converterReais();
