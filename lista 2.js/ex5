//5. Tendo como dados de entrada a altura e o sexo de uma pessoa,
//construa um algoritmo que calcule seu peso ideal, utilizando as seguintes expressões:
//● Para homens: 72.7 * h −58 ;
//● Para mulheres: 62.1* h −44.7.
//Obs.: Usuário ideal - ele não irá digitar valores incorretos.

let prompt = require('prompt-sync')();
function calcularPesoIdeal() {
    let altura = parseFloat(prompt('Digite a altura da pessoa (em metros): '));
    let sexo = prompt('Digite o sexo da pessoa (M para masculino, F para feminino): ').toUpperCase();
    let pesoIdeal;
    if (sexo === 'M') {
        pesoIdeal = 72.7 * altura - 58;
    } else if (sexo === 'F') {
        pesoIdeal = 62.1 * altura - 44.7;
    } else {
        console.log('Sexo inválido. Por favor, digite M para masculino ou F para feminino.');
        return;
    }
    console.log(`O peso ideal para a pessoa é: ${pesoIdeal.toFixed(2)} kg`);
}
calcularPesoIdeal();
