let prompt = require("prompt-sync")();
function calcularValorFinal() {
    let corEtiqueta = prompt("Digite a cor da etiqueta (verde ou amarelo): ");
    let quantidade = parseInt(prompt("Digite a quantidade do produto: "));
    let valorUnitario = parseFloat(prompt("Digite o valor unitário do produto: "));
    let desconto = 0;
    if (corEtiqueta.toLowerCase() === "verde") {
        if (quantidade <= 10) {
            desconto = 0.05;
        } else {
            desconto = 0.10;
        }
    } else if (corEtiqueta.toLowerCase() === "amarelo") {
        if (quantidade <= 5) {
            desconto = 0.15;
        } else {
            desconto = 0.20;
        }
    } else {
        console.log("Cor da etiqueta inválida. Use 'verde' ou 'amarelo'.");
        return;
    }
    let valorTotal = quantidade * valorUnitario;
    let valorDesconto = valorTotal * desconto;
    let valorFinal = valorTotal - valorDesconto;
    console.log(`Valor total: R$ ${valorTotal.toFixed(2)}`);
    console.log(`Desconto: R$ ${valorDesconto.toFixed(2)}`);
    console.log(`Valor final a ser pago: R$ ${valorFinal.toFixed(2)}`);
}
calcularValorFinal();
