//1. Criar um programa em JavaScript que, a partir do tipo do paciente,
//calcule a dosagem de determinado medicamento e imprima a receita
//informando a quantidade de gotas do medicamento e a dosagem em
//mg que o paciente deve tomar.
//Considere que o medicamento em questão possui 400 mg por ml, e
//que cada ml corresponde a 14 gotas.
//Deve ser lido o tipo do paciente e calcule a dosagem em mg e em
//gotas.
//Leve em consideração a tabela abaixo:
//Tipo do Paciente Dosagem
//1 - Bebê 600 mg
//2 - Adolescente 1600 mg
//3 - Adulto 4600 mg
//4 - Idoso 2450 mg

let prompt = require("prompt-sync")();
function calcularDosagem() {
    let tipoPaciente = parseInt(prompt("Digite o tipo do paciente (1 - Bebê, 2 - Adolescente, 3 - Adulto, 4 - Idoso): "));
    let dosagemMg;
    switch (tipoPaciente) {
        case 1:
            dosagemMg = 600;
            break;
        case 2:
            dosagemMg = 1600;
            break;
        case 3:
            dosagemMg = 4600;
            break;
        case 4:
            dosagemMg = 2450;
            break;
        default:
            console.log("Tipo de paciente inválido.");
            return;
    }
    let gotasPorMl = 14;
    let mgPorMl = 400;
    let dosagemMl = dosagemMg / mgPorMl;
    let gotas = dosagemMl * gotasPorMl;
    console.log(`A dosagem para o paciente é de ${dosagemMg} mg, o que corresponde a ${gotas.toFixed(2)} gotas.`);
}
calcularDosagem();
