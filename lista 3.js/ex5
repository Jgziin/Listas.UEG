//5. Dados quatro números distintos, desenvolver um programa que
//determine e imprima a soma dos três menores.

let prompt = require("prompt-sync")();
function somaTresMenores() {
    let numeros = [];
    for (let i = 0; i < 4; i++) {
        let num = parseFloat(prompt(`Digite o número ${i + 1}: `));
        numeros.push(num);
    }
    numeros.sort((a, b) => a - b); // Ordena os números em ordem crescente
    let soma = numeros[0] + numeros[1] + numeros[2]; // Soma os três menores
    console.log(`A soma dos três menores números é: ${soma}`);
}
somaTresMenores();
