//3. O número 3025 possui a seguinte característica:
//● 30 + 25 = 55
//● 55
//2 = 3025
//Fazer um algoritmo que leia um número inteiro de 4 dígitos e calcule
//se este tem a característica descrita acima.
//Obs.: Usuário ideal - ele não irá digitar valores incorretos.

let prompt = require('prompt-sync')();
function verificarCaracteristica() {
    let numero = prompt('Digite um número inteiro de 4 dígitos: ');

    let parte1 = parseInt(numero.substring(0, 2));
    let parte2 = parseInt(numero.substring(2, 4));
    let soma = parte1 + parte2;
    if (soma * soma === parseInt(numero)) {
        console.log(`O número ${numero} possui a característica descrita.`);
    } else {
        console.log(`O número ${numero} não possui a característica descrita.`);
    }
}
verificarCaracteristica();
    