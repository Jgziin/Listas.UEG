//8. Um posto de combustível vende três tipos de combustível : álcool,
//diesel e gasolina. O preço por litro de combustível é apresentado na
//tabela a seguir. Faça um algoritmo que leia uma opção que representa
//o tipo de combustível comprado (1, 2 ou 3) e a quantidade em litros. O
//programa deve imprimir o valor em reais a ser pago pelo combustível.

//Combustível Preço por Litro
//1 – Álcool R$ 4,805
//2 – Diesel R$ 5,953
//3 – Gasolina R$ 6,565

let prompt = require('prompt-sync')();
function calcularValorCombustivel() {
    let tipoCombustivel = parseInt(prompt('Digite o tipo de combustível comprado (1 - Álcool, 2 - Diesel, 3 - Gasolina): '));
    let quantidadeLitros = parseFloat(prompt('Digite a quantidade em litros: '));
    let precoPorLitro;
    switch (tipoCombustivel) 
    {   case 1:
            precoPorLitro = 4.805;
            break;      
        case 2:
            precoPorLitro = 5.953;
            break;
        case 3:
            precoPorLitro = 6.565;
            break;
        default:
            console.log('Opção de combustível inválida.');
            return;
    }
    let valorTotal = precoPorLitro * quantidadeLitros;
    console.log(`O valor a ser pago pelo combustível é: R$ ${valorTotal.toFixed(2)}`);
}   
calcularValorCombustivel();
    