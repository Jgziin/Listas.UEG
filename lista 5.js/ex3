// 3. Números palíndromos são aqueles que escritos da direita para
// esquerda ou da esquerda para direita tem o mesmo valor. Exemplo
// 929, 44, 97379. Fazer um algoritmo que dado um número de 5 dígitos;
// calcule e escreva se este é ou não palíndromo.

let prompt = require('prompt-sync')();
function verificarPalindromo() {
    let numero = prompt('Digite um número de 5 dígitos: ');
    if (numero.length !== 5) {
        console.log('Número inválido. Por favor, digite um número de 5 dígitos.');
        return;
    }
    let palindromo = numero === numero.split('').reverse().join('');
    if (palindromo) {
        console.log(`${numero} é um número palíndromo.`);
    }
    else {
        console.log(`${numero} não é um número palíndromo.`);
    }
}
verificarPalindromo();